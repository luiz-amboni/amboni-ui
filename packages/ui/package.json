{
  "name": "@amboni/ui",
  "version": "0.3.5",
  "description": "Componentes React do design system Amboni — neutro, temável e acessível por prova",
  "type": "module",
  "license": "MIT",
  "author": "Luiz Amboni",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "sideEffects": [
    "*.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luiz-amboni/amboni-ui.git",
    "directory": "packages/ui"
  },
  "keywords": [
    "react",
    "design-system",
    "ui",
    "components",
    "a11y",
    "wcag",
    "headless"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "test": "npm run typecheck && vitest run",
    "dev": "vite build --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "size": "size-limit",
    "cobertura": "vitest run --coverage",
    "galeria": "vite --config galeria/vite.config.ts",
    "typecheck:visual": "tsc -p tsconfig.visual.json --noEmit",
    "visual": "playwright test",
    "visual:layout": "playwright test layout.spec.ts",
    "visual:ver": "playwright show-report"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@amboni/tokens": "0.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.10",
    "axe-core": "^4.12.1",
    "jsdom": "^25.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "size-limit": "^12.1.0",
    "typescript": "^5.7.2",
    "vite": "^7.3.6",
    "vitest": "^4.1.10",
    "vitest-axe": "^0.1.0"
  },
  "homepage": "https://luiz-amboni.github.io/amboni-ui/",
  "bugs": {
    "url": "https://github.com/luiz-amboni/amboni-ui/issues"
  },
  "size-limit": [
    {
      "name": "a biblioteca inteira (JS)",
      "path": "dist/index.js",
      "limit": "26 kB"
    },
    {
      "name": "o CSS inteiro",
      "path": "dist/styles.css",
      "limit": "11 kB"
    },
    {
      "name": "importando só o Button",
      "path": "dist/index.js",
      "import": "{ Button }",
      "limit": "1 kB"
    },
    {
      "name": "uma tela de CRM típica",
      "path": "dist/index.js",
      "import": "{ Button, Campo, CampoForm, Tabela, Selo, Paginacao }",
      "limit": "12 kB"
    }
  ]
}
