{
  "name": "@amboni/tokens",
  "version": "0.0.0",
  "description": "Design tokens do sistema Amboni — cor, tipografia, espaço, movimento",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build": "tsc -p tsconfig.json && node dist/build-css.js",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens.css": "./tokens.css"
  },
  "files": [
    "dist",
    "tokens.css"
  ],
  "sideEffects": [
    "*.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luiz-amboni/amboni-ui.git",
    "directory": "packages/tokens"
  },
  "keywords": [
    "design-tokens",
    "design-system",
    "css-variables",
    "a11y",
    "wcag"
  ],
  "author": "Luiz Amboni"
}
